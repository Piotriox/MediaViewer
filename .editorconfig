# EditorConfig helps maintain consistent coding style across different editors
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,vue,json}]
indent_style = space
indent_size = 2

[*.{css,scss}]
indent_style = space
indent_size = 2

[*.{rs}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
